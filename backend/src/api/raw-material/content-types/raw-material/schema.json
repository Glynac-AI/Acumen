{
    "kind": "collectionType",
    "collectionName": "raw_materials",
    "info": {
        "singularName": "raw-material",
        "pluralName": "raw-materials",
        "displayName": "Raw Material",
        "description": "Internal source material only. Used for intake before processing into Playbook Pages or Knowledge Base articles. Optionally synced to Wiki.js."
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "type": {
            "type": "enumeration",
            "enum": [
                "meeting-notes",
                "research",
                "email-thread",
                "document",
                "recording",
                "other"
            ],
            "required": true
        },
        "product": {
            "type": "enumeration",
            "enum": [
                "acumen-strategy",
                "glynac",
                "phh",
                "sylvan",
                "toll-booth"
            ],
            "required": true
        },
        "file": {
            "type": "media",
            "multiple": false,
            "allowedTypes": ["files", "images", "videos", "audios"]
        },
        "external_url": {
            "type": "string"
        },
        "notes": {
            "type": "text"
        },
        "sections_to_update": {
            "type": "json",
            "default": []
        },
        "processed": {
            "type": "boolean",
            "default": false
        },
        "resulting_pages": {
            "type": "json",
            "default": []
        },
        "date": {
            "type": "date",
            "required": true
        },
        "syncToWiki": {
            "type": "boolean",
            "default": false,
            "description": "When true, this material is synced to Wiki.js on create/update"
        },
        "wikiPath": {
            "type": "string",
            "description": "Custom Wiki.js page path (defaults to /raw-material/{title-slug})"
        },
        "wikiTags": {
            "type": "string",
            "description": "Comma-separated tags for the Wiki.js page"
        },
        "lastSyncedAt": {
            "type": "datetime"
        },
        "lastSyncStatus": {
            "type": "enumeration",
            "enum": ["success", "failed", "pending"]
        },
        "lastSyncError": {
            "type": "text"
        },
        "wikiPageId": {
            "type": "integer",
            "description": "Stored Wiki.js page ID for direct update/delete operations"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "rawMaterials"
        }
    }
}
