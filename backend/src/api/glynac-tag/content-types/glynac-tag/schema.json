{
    "kind": "collectionType",
    "collectionName": "glynac_tags",
    "info": {
        "singularName": "glynac-tag",
        "pluralName": "glynac-tags",
        "displayName": "Glynac Tag",
        "description": "Tags for Glynac blog"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "posts": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::glynac-blog-post.glynac-blog-post",
            "mappedBy": "tags"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "glynacTags"
        }
    }
}