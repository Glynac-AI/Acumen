{
    "kind": "collectionType",
    "collectionName": "playbook_pages",
    "info": {
        "singularName": "playbook-page",
        "pluralName": "playbook-pages",
        "displayName": "Playbook Page",
        "description": "Main live knowledge page model. Syncs one-way to Wiki.js when approval_status is live and sync_to_wiki is true."
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "summary": {
            "type": "text"
        },
        "content": {
            "type": "richtext",
            "required": true
        },
        "product": {
            "type": "enumeration",
            "enum": [
                "acumen-strategy",
                "glynac",
                "phh",
                "sylvan",
                "toll-booth"
            ],
            "required": true
        },
        "section": {
            "type": "string",
            "required": true
        },
        "wiki_path": {
            "type": "string",
            "required": true
        },
        "sync_to_wiki": {
            "type": "boolean",
            "default": false
        },
        "approval_status": {
            "type": "enumeration",
            "enum": [
                "draft",
                "under-review",
                "approved",
                "live",
                "unpublished"
            ],
            "default": "draft",
            "required": true
        },
        "visibility_groups": {
            "type": "json",
            "default": []
        },
        "content_owner": {
            "type": "string"
        },
        "created_by_user": {
            "type": "string"
        },
        "last_updated_by": {
            "type": "string"
        },
        "tags": {
            "type": "json",
            "default": []
        },
        "last_reviewed": {
            "type": "datetime"
        },
        "review_cadence": {
            "type": "enumeration",
            "enum": [
                "monthly",
                "quarterly",
                "biannual",
                "annual",
                "as-needed"
            ]
        },
        "lastSyncedAt": {
            "type": "datetime"
        },
        "lastSyncStatus": {
            "type": "enumeration",
            "enum": ["success", "failed", "pending"]
        },
        "lastSyncError": {
            "type": "text"
        },
        "wikiPageId": {
            "type": "integer",
            "description": "Stored Wiki.js page ID for direct update/delete operations"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "playbookPages"
        }
    }
}
