{
    "kind": "collectionType",
    "collectionName": "playbooks",
    "info": {
        "singularName": "playbook",
        "pluralName": "playbooks",
        "displayName": "Playbook",
        "description": "Operational playbook pages — step-by-step guides, SOPs, and repeatable workflows synced to Wiki.js"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "maxLength": 200
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true
        },
        "summary": {
            "type": "text",
            "maxLength": 500
        },
        "body": {
            "type": "richtext",
            "required": true
        },
        "product": {
            "type": "string",
            "maxLength": 100,
            "description": "Product or service this playbook applies to"
        },
        "persona": {
            "type": "string",
            "maxLength": 100,
            "description": "Target audience / role (e.g. 'Compliance Officer', 'Advisor')"
        },
        "category": {
            "type": "string",
            "maxLength": 100,
            "description": "Playbook category (e.g. 'Onboarding', 'Incident Response')"
        },
        "owner": {
            "type": "string",
            "maxLength": 100,
            "description": "Team or individual responsible for maintaining this playbook"
        },
        "reviewDate": {
            "type": "date",
            "description": "Next scheduled review date"
        },
        "priority": {
            "type": "enumeration",
            "enum": ["critical", "high", "medium", "low"],
            "default": "medium"
        },
        "status": {
            "type": "enumeration",
            "enum": ["draft", "in-review", "approved", "archived"],
            "default": "draft"
        },
        "syncToWiki": {
            "type": "boolean",
            "default": false,
            "description": "When true, this playbook is synced to Wiki.js on create/update/publish"
        },
        "wikiPath": {
            "type": "string",
            "description": "Custom Wiki.js page path (defaults to /playbook/{slug})"
        },
        "wikiTags": {
            "type": "string",
            "description": "Comma-separated tags for the Wiki.js page"
        },
        "lastSyncedAt": {
            "type": "datetime"
        },
        "lastSyncStatus": {
            "type": "enumeration",
            "enum": ["success", "failed", "pending"]
        },
        "lastSyncError": {
            "type": "text"
        },
        "wikiPageId": {
            "type": "integer",
            "description": "Stored Wiki.js page ID for direct update/delete operations"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "playbooks"
        }
    }
}
