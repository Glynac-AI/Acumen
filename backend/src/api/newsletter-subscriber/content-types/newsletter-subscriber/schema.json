{
    "kind": "collectionType",
    "collectionName": "newsletter_subscribers",
    "info": {
        "singularName": "newsletter-subscriber",
        "pluralName": "newsletter-subscribers",
        "displayName": "Newsletter Subscriber",
        "description": "Newsletter email subscribers"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "email": {
            "type": "email",
            "required": true,
            "unique": true
        },
        "subscribedAt": {
            "type": "datetime",
            "required": true
        },
        "status": {
            "type": "string",
            "default": "active",
            "required": true
        },
        "source": {
            "type": "enumeration",
            "enum": [
                "Homepage",
                "global_footer",
                "Article_CTA",
                "Author_CTA",
                "Website"
            ]
        },
        "unsubscribeAt": {
            "type": "datetime"
        },
        "unsubscribeReason": {
            "type": "text"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "newsletterSubscribers"
        }
    }
}
