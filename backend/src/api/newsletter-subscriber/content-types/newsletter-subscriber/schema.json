        "email": {
            "type": "email",
            "required": true,
            "unique": true
        },
        "subscribedAt": {
            "type": "datetime",
            "required": true
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "Active",
                "Unsubscribed"
            ],
            "default": "Active",
            "required": true
        },
        "source": {
            "type": "enumeration",
            "enum": [
                "Homepage",
                "Article_Footer",
                "Sidebar",
                "Popup",
                "Other"
            ]
        }
    }
}