{
    "kind": "collectionType",
    "collectionName": "blog_posts",
    "info": {
        "singularName": "blog-post",
        "pluralName": "blog-posts",
        "displayName": "Blog Post",
        "description": "Blog posts for Glynac tenant"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true,
            "maxLength": 200,
            "description": "Blog post title (max 70 chars recommended for SEO)"
        },
        "slug": {
            "type": "uid",
            "targetField": "title",
            "required": true,
            "description": "URL-friendly identifier (auto-generated from title)"
        },
        "excerpt": {
            "type": "text",
            "required": true,
            "maxLength": 500,
            "description": "Short description for cards and meta tags (2-3 sentences, 120-160 chars ideal for SEO)"
        },
        "content": {
            "type": "richtext",
            "required": true,
            "description": "Main blog post content in markdown format"
        },
        "coverImage": {
            "type": "media",
            "multiple": false,
            "required": true,
            "allowedTypes": [
                "images"
            ],
            "description": "Featured image (recommended: 1600x900px minimum, under 500KB)"
        },
        "category": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::category.category",
            "inversedBy": "blogPosts",
            "description": "Post category (select from existing categories)"
        },
        "tags": {
            "type": "json",
            "required": false,
            "description": "Array of tags (e.g., ['AI', 'Automation', 'Compliance'])"
        },
        "readTime": {
            "type": "string",
            "required": true,
            "maxLength": 50,
            "description": "Estimated reading time (e.g., '5 min read', '8 min read')"
        },
        "author": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::author.author",
            "inversedBy": "blogPosts",
            "description": "Blog post author (select from existing authors)"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant",
            "inversedBy": "blogPosts",
            "description": "Associated tenant (should be set to Glynac)"
        }
    }
}