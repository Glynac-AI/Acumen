{
    "kind": "collectionType",
    "collectionName": "glynac_authors",
    "info": {
        "singularName": "glynac-author",
        "pluralName": "glynac-authors",
        "displayName": "Glynac Author",
        "description": "Authors for Glynac blog"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "role": {
            "type": "string",
            "required": true
        },
        "bio": {
            "type": "text"
        },
        "profileImage": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "posts": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::glynac-blog-post.glynac-blog-post",
            "mappedBy": "author"
        }
    }
}